{
  "name": "ifcxs",
  "version": "0.0.1",
  "private": true,
  "description": "空間を一次要素とするテキストネイティブ建築記述の探求 — writing architecture, not buildings",
  "type": "module",
  "scripts": {
    "ifcxs": "tsx src/cli.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check:examples": "tsx src/cli.ts check examples/two-rooms.ifcxs",
    "plan:examples": "tsx src/cli.ts plan examples/two-rooms.ifcxs -o out/two-rooms.svg"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
