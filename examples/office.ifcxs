# 小さなオフィス — 2フロア + 屋上レベル
# 基本計画の解像度で書く。垂れ壁や建具詳細は表現しない — 省略ではなく抽象度の選択。
# 高さの一貫性は level の宣言 (z / h / slab) と check の不変量が担保する。

ifcxs 0.1
name 小さなオフィス
unit mm

grid X 0 6400 12800 19200
grid Y 0 6400 8000 12000

level L1 0 h:2700
level L2 4000 h:2700 slab:1300
level R 8000 slab:1300          # 屋根面。L2の空間の上限を与える

space /out exterior name:外部

# ---- 1階: エントランス+事務室、北側にコア ----
space /L1/hall     hall     X1..X2 Y1..Y2       name:エントランスホール use:common floor:フローリング h:6700   # 吹抜けで2層分
  area X1..X1+1800 Y1..Y2 name:土間 floor:モルタル   # 数えない分節: 室は割れない。面積はホールのまま
space /L1/office   office   X2..X4 Y1..Y2       name:事務室 use:rentable
space /L1/corridor corridor X1..X4 Y2..Y3       name:廊下 use:common
space /L1/stair    stair    X1..X1+3200 Y3..Y4  name:階段室 use:common
space /L1/ev       ev       X1+3200..X2 Y3..Y4  name:EV use:common
space /L1/wc-m     wc       X2..X2+3000 Y3..Y4  name:男子WC use:common
space /L1/wc-w     wc       X2+3000..X3 Y3..Y4  name:女子WC use:common
space /L1/machine  machine  X3..X4 Y3..Y4       name:機械室 use:common

boundary /L1/hall /L1/office t:120 spec:LGS
  door w:1000 at:0.8
boundary /L1/hall /L1/corridor type:open
boundary /L1/office /L1/corridor t:120 spec:LGS
  door w:900
  seg at:0.75 w:3600 spec:ガラスパーティション   # 数えない分節: 同じ境界のまま壁材だけ変わる
boundary /L1/corridor /L1/stair t:180 spec:RC fire:60
  door w:900 name:ST1
boundary /L1/corridor /L1/ev t:180 spec:RC
  door w:900 name:EV1
boundary /L1/corridor /L1/wc-m t:120 spec:LGS
  door w:800
boundary /L1/corridor /L1/wc-w t:120 spec:LGS
  door w:800
boundary /L1/corridor /L1/machine t:120 spec:LGS
  door w:800
boundary /L1/stair /L1/ev t:180 spec:RC fire:60
boundary /L1/ev /L1/wc-m t:180 spec:RC
boundary /L1/wc-m /L1/wc-w t:80 spec:LGS
boundary /L1/wc-w /L1/machine t:120 spec:LGS

boundary /L1/hall /out t:180 spec:EW1 fire:60
  door w:1800 edge:S name:エントランス
  window w:2400 edge:W sill:800
boundary /L1/office /out t:180 spec:EW1 fire:60
  window w:3600 edge:S at:0.25 sill:800
  window w:3600 edge:S at:0.72 sill:800
  window w:2400 edge:E sill:800
boundary /L1/corridor /out t:180 spec:EW1 fire:60
boundary /L1/stair /out t:180 spec:EW1 fire:60
boundary /L1/ev /out t:180 spec:EW1
boundary /L1/wc-m /out t:180 spec:EW1
boundary /L1/wc-w /out t:180 spec:EW1
boundary /L1/machine /out t:180 spec:EW1

# ---- 2階: 会議室+執務室 (南の廊下芯Y2を跨いで広がる)、コアは1階と同位置 ----
space /L2/void     void     X1..X2 Y1..Y2       name:エントランス吹抜け
space /L2/office   office   X2..X4 Y1..Y3       name:執務室 use:rentable floor:タイルカーペット
  area X3+3200..X4 Y1..Y1+3200 name:リフレッシュコーナー floor:フローリング
space /L2/corridor corridor X1..X2 Y2..Y3       name:廊下 use:common
space /L2/stair    stair    X1..X1+3200 Y3..Y4  name:階段室 use:common
space /L2/ev       ev       X1+3200..X2 Y3..Y4  name:EV use:common
space /L2/wc-m     wc       X2..X2+3000 Y3..Y4  name:男子WC use:common
space /L2/wc-w     wc       X2+3000..X3 Y3..Y4  name:女子WC use:common
space /L2/machine  machine  X3..X4 Y3..Y4       name:倉庫 use:common

boundary /L2/void /L2/office t:120 spec:LGS
boundary /L2/void /L2/corridor t:120 spec:腰壁+手すり air:1   # 吹抜けに面する — 遮蔽しない
boundary /L2/office /L2/corridor t:120 spec:LGS
  door w:900
boundary /L2/corridor /L2/stair t:180 spec:RC fire:60
  door w:900 name:ST2
boundary /L2/corridor /L2/ev t:180 spec:RC
  door w:900 name:EV2
boundary /L2/office /L2/wc-m t:120 spec:LGS
  door w:800
boundary /L2/office /L2/wc-w t:120 spec:LGS
  door w:800
boundary /L2/office /L2/machine t:120 spec:LGS
  door w:800
boundary /L2/stair /L2/ev t:180 spec:RC fire:60
boundary /L2/ev /L2/wc-m t:180 spec:RC
boundary /L2/wc-m /L2/wc-w t:80 spec:LGS
boundary /L2/wc-w /L2/machine t:120 spec:LGS

boundary /L2/void /out t:180 spec:EW1 fire:60
  window w:3600 edge:S sill:800    # 吹抜けの大開口
boundary /L2/office /out t:180 spec:EW1 fire:60
  window w:3600 edge:S at:0.3 sill:800
  window w:3600 edge:S at:0.75 sill:800
  window w:2400 edge:E sill:800
boundary /L2/corridor /out t:180 spec:EW1
boundary /L2/stair /out t:180 spec:EW1 fire:60
boundary /L2/ev /out t:180 spec:EW1
boundary /L2/wc-m /out t:180 spec:EW1
boundary /L2/wc-w /out t:180 spec:EW1
boundary /L2/machine /out t:180 spec:EW1

# ---- 垂直: 床は書かない (levelのslabが既定)。例外 — 繋がる場所と抜ける場所 — だけ書く ----
boundary /L1/stair /L2/stair type:stair
boundary /L1/ev /L2/ev type:shaft
boundary /L1/hall /L2/void type:void   # エントランスは2層吹抜け — 床の不在も境界で書く
