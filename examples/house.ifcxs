# 小さな戸建住宅 — メゾネットの原型 + 敷地 (MUN-149/150)
# パスの第一義は集計の階層。レベルは既定でパス先頭から読むが、この家は /home の下に
# 全室を束ね、level: 属性で階を明示する (ADR-0008)。LDK上部は部分吹抜け (被覆1/3)。
#
# 敷地: /out は方角・性格ごとの複数のexterior空間に割れる (道路は road:幅員 — ADR-0009)。
# 地上の外部空間 (庭) はL1上の実在の空間として建物の周りをタイルし、
# 敷地 = zone site:1 (宣言面積と導出面積を site コマンドが突き合わせる)。
# L1の平面図はそのまま配置図兼用になる。

ifcxs 0.1
name 小さな戸建住宅
unit mm

grid X 0 3640 7280
grid Y 0 3640 7280

level L1 0 h:2400
level L2 2900 h:2400 slab:500
level R 5800 slab:500

# ---- 外部 (敷地の外) — 方角・性格ごとに割る ----
space /out/road exterior name:南側道路 road:6000
space /out/n    exterior name:北側隣地
space /out/e    exterior name:東側隣地
space /out/w    exterior name:西側隣地

# ---- 敷地 — 地上の外部空間が建物の周りをタイルする ----
zone /site name:敷地 site:1 area:126.24
space /site/garden garden X1-1500..X3+1500 Y1-4000..Y1 level:L1 name:南庭
space /site/west   yard   X1-1500..X1 Y1..Y3+1000      level:L1 name:西側通路
space /site/east   yard   X3..X3+1500 Y1..Y3+1000      level:L1 name:東側通路
space /site/north  yard   X1..X3 Y3..Y3+1000           level:L1 name:北側通路

zone /home name:住戸 use:exclusive

space /home/ldk   ldk     X1..X2 Y1..Y3 + X2..X3 Y1..Y2 level:L1 name:LDK floor:オーク
space /home/hall1 hall    X2..X3 Y2..Y3 level:L1 name:玄関・階段
space /home/bed1  bedroom X1..X2 Y1..Y3 level:L2 name:主寝室
space /home/void  void    X2..X3 Y1..Y2 level:L2 name:リビング上部
space /home/hall2 hall    X2..X3 Y2..Y3 level:L2 name:2階ホール

# ---- 1階: 室と庭の境界 (実在の矩形同士 — 線分は正確に導出される) ----
boundary /home/ldk /home/hall1 t:120 spec:LGS
  door w:800 edge:E hinge:S swing:b
boundary /home/ldk /site/garden t:150 spec:EW
  window w:2600 h:2200 sill:0 name:掃き出し窓   # 庭は上が開いている → 採光1.0
boundary /home/ldk /site/west t:150 spec:EW
  window w:1650 h:1100 sill:900
boundary /home/ldk /site/east t:150 spec:EW
boundary /home/ldk /site/north t:150 spec:EW
boundary /home/hall1 /site/east t:150 spec:EW
  door w:900 name:玄関
boundary /home/hall1 /site/north t:150 spec:EW

# ---- 庭同士は連続 ----
boundary /site/garden /site/west type:open
boundary /site/garden /site/east type:open
boundary /site/west /site/north type:open
boundary /site/east /site/north type:open

# ---- 敷地境界: 塀は境界のspec語彙 (外気は遮らない air:1)。門扉は扉 ----
boundary /site/garden /out/road edge:S t:120 spec:ブロック塀+フェンス air:1 h:1200
  door w:900 name:門扉
boundary /site/garden /out/w edge:W t:120 spec:ブロック塀 air:1 h:1200
boundary /site/garden /out/e edge:E t:120 spec:ブロック塀 air:1 h:1200
boundary /site/west /out/w edge:W t:120 spec:ブロック塀 air:1 h:1200
boundary /site/west /out/n edge:N t:120 spec:ブロック塀 air:1 h:1200
boundary /site/east /out/e edge:E t:120 spec:ブロック塀 air:1 h:1200
boundary /site/east /out/n edge:N t:120 spec:ブロック塀 air:1 h:1200
boundary /site/north /out/n edge:N t:120 spec:ブロック塀 air:1 h:1200

# ---- 2階: 上階の外壁は方角別のexteriorに面する ----
boundary /home/bed1 /out/road edge:S t:150 spec:EW
  window w:2600 h:2200 sill:800
boundary /home/bed1 /out/w edge:W t:150 spec:EW
boundary /home/bed1 /out/n edge:N t:150 spec:EW
boundary /home/bed1 /home/void t:120 spec:LGS
boundary /home/bed1 /home/hall2 t:120 spec:LGS
  door w:800
boundary /home/void /home/hall2 t:120 spec:手すり air:1 h:1100
boundary /home/void /out/road edge:S t:150 spec:EW
  window w:2600 h:1100 sill:1100 name:吹抜けの高窓
boundary /home/void /out/e edge:E t:150 spec:EW
boundary /home/hall2 /out/e edge:E t:150 spec:EW
boundary /home/hall2 /out/n edge:N t:150 spec:EW

# ---- 垂直: 内部階段と部分吹抜け ----
boundary /home/hall1 /home/hall2 type:stair
boundary /home/ldk /home/void type:void   # 部分吹抜け — LDKの天井高は階高内のまま
